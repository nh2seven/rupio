# ── ezbookkeeping ─────────────────────────────────────────────────────────────
# Generate with: docker run --rm mayswind/ezbookkeeping ./ezbookkeeping security gen-secret-key
EBK_SECRET_KEY=

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_ADMIN_PASSWORD=
POSTGRES_N8N_PASSWORD=
POSTGRES_FINANCE_PASSWORD=

# ── n8n ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# ── Backup / rclone ───────────────────────────────────────────────────────────
# Format: remotename:path — configure rclone first (see README)
RCLONE_REMOTE=gdrive:rupio-backups

# ── GroqCloud ─────────────────────────────────────────────────────────────────
# Obtain from console.groq.com — enable ZDR before generating key
GROQ_API_KEY=