            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "GroqCloud fallback",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "GroqCloud fallback": {
      "main": [
        [
          {
            "node": "Log GroqCloud call",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log GroqCloud call": {
      "main": [
        [
          {
            "node": "Dedup check",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Dedup check": {
      "main": [
        [
          {
            "node": "Is duplicate?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Is duplicate?": {
      "main": [
        [],
        [
          {
            "node": "Write to ezbookkeeping",
